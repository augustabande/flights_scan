# Copia in .env per test locale (non committare mai questo file con valori reali)

# OPZIONALE — Amadeus (fonte secondaria)
# Registrazione gratuita: https://developers.amadeus.com
# Crea una Self-Service app, usa le credenziali Production
AMADEUS_CLIENT_ID=your_amadeus_client_id
AMADEUS_SECRET=your_amadeus_secret

# OBBLIGATORIO per push notification
# Scegli un topic privato (stringa casuale es: "fue-flights-abc123")
# Iscriviti al topic nell'app ntfy (iOS/Android, gratuita)
NTFY_TOPIC=fue-flights-your-secret-topic

# OPZIONALE — Email fallback (Gmail)
# Per EMAIL_PASSWORD usa una "App Password" Google, non la password dell'account
EMAIL_TO=tua@email.com
EMAIL_FROM=mittente@gmail.com
EMAIL_PASSWORD=your_gmail_app_password
